# Google Cloud OAuth 2.0 Client ID
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Add authorized origins: https://your-app.vercel.app and http://localhost:5173
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# New multi-tenant GAS URL (deploy gas-script-v2.js as Web App)
# Execute as: Me | Who has access: Anyone
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_NEW_GAS_ID/exec

# Your Google account email (the GAS owner — user sheets will be shared to this)
VITE_GAS_OWNER_EMAIL=your-email@gmail.com
